number_to_calculate = int(input("Please choose a number to calculate: "))
chosen_percent = int(input("Please choose a percent [1-100] to calculate a given number: "))

calculated_percent = chosen_percent / 100

print(f"Chosen percent is: {chosen_percent}%")
print(f"Chosen number is: {number_to_calculate}")

calculated_sum = calculated_percent * number_to_calculate

print(f"{chosen_percent}% of {number_to_calculate} is {calculated_sum}")
